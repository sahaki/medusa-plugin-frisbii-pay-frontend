{
  "name": "@montaekung/medusa-plugin-frisbii-pay-frontend",
  "version": "0.1.0-beta.1",
  "description": "Frontend components for Frisbii Payment integration in Medusa Next.js storefronts",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "medusa",
    "medusa-plugin",
    "medusa-storefront",
    "frisbii",
    "reepay",
    "payment",
    "next.js",
    "react"
  ],
  "author": "MontaeKung",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sahaki/medusa-plugin-frisbii-pay-frontend.git"
  },
  "bugs": {
    "url": "https://github.com/sahaki/medusa-plugin-frisbii-pay-frontend/issues"
  },
  "homepage": "https://github.com/sahaki/medusa-plugin-frisbii-pay-frontend#readme",
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@medusajs/types": "^2.0.0",
    "@medusajs/ui": "^3.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0 || ^19.0.0",
    "@types/react-dom": "^18.0.0 || ^19.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.2.5",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {},
  "publishConfig": {
    "access": "public"
  }
}
